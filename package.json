{
  "name": "is-in.nz",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "typecheck": "pnpm -r run typecheck",
    "dev:public-site": "pnpm --filter public-site dev",
    "dev:email-inbound": "pnpm --filter email-inbound dev",
    "dev:management": "pnpm --filter management dev",
    "dev:management:pages": "pnpm --filter management dev:pages",
    "build:management": "pnpm --filter management build",
    "deploy:management": "bash scripts/deploy-management.sh production",
    "deploy:management:staging": "bash scripts/deploy-management.sh staging"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "vite": "^8.0.14",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "devalue": ">=5.8.1"
    }
  }
}

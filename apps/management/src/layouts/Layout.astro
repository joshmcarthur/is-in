---
interface Props {
  title: string;
  mainClass?: string;
}
const { title, mainClass } = Astro.props;
---
<!doctype html>
<html lang="en-NZ">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · is-in.nz</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class={mainClass}>
      <slot />
    </main>
  </body>
</html>

---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import { ROOT_DOMAIN } from "../siteDomain";

const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
const docsUrl = "https://github.com/joshmcarthur/is-in#readme";
const contactUrl = "https://github.com/joshmcarthur/is-in/issues";
---

<Layout title="Dashboard" mainClass="main--wide">
  <div class="stack">
    <div class="toolbar">
      <h1 class="title site-host font-mono" id="site-host"></h1>
      <button type="button" class="btn-link sign-out">Sign out</button>
    </div>
    <p class="muted">Your address on the New Zealand internet.</p>

    <div class="stack" role="navigation" aria-label="Account">
      <article class="feature-card" id="your-page">
        <span class="feature-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M20 21a8 8 0 0 0-16 0"></path>
            <circle cx="12" cy="8" r="4"></circle>
          </svg>
        </span>
        <div class="feature-card__body">
          <h2 class="feature-card__title">Your page</h2>
          <p class="feature-card__desc muted">Edit your profile and links</p>
        </div>
        <div class="feature-card__actions">
          <a class="feature-card__action" id="view-page" href="#">View</a>
          <span class="feature-card__action feature-card__action--disabled" aria-disabled="true">Edit</span>
        </div>
      </article>

      <article class="feature-card" id="mail">
        <span class="feature-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M4 6h16v12H4z"></path>
            <path d="m4 6 8 7 8-7"></path>
          </svg>
        </span>
        <div class="feature-card__body">
          <h2 class="feature-card__title">Email aliases</h2>
          <p class="feature-card__desc muted" id="aliases-desc">Create @yourname.is-in.nz addresses</p>
        </div>
        <div class="feature-card__actions">
          <span class="feature-card__action feature-card__action--disabled" aria-disabled="true">Manage</span>
        </div>
      </article>

      <article class="feature-card" id="links">
        <span class="feature-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M10 13a5 5 0 0 1 7.07 0l1.41 1.41a5 5 0 0 1 0 7.07 5 5 0 0 1-7.07 0"></path>
            <path d="M14 11a5 5 0 0 0-7.07 0L5.52 12.4a5 5 0 0 0 0 7.07 5 5 0 0 0 7.07 0"></path>
          </svg>
        </span>
        <div class="feature-card__body">
          <h2 class="feature-card__title">Short URLs</h2>
          <p class="feature-card__desc muted">Create short, easy to share links</p>
        </div>
        <div class="feature-card__actions">
          <span class="feature-card__action feature-card__action--disabled" aria-disabled="true">Manage</span>
        </div>
      </article>

      <article class="feature-card">
        <span class="feature-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M5 12h12"></path>
            <path d="m13 6 6 6-6 6"></path>
          </svg>
        </span>
        <div class="feature-card__body">
          <h2 class="feature-card__title">Web forwarding</h2>
          <p class="feature-card__desc muted">Send visitors to another website</p>
        </div>
        <div class="feature-card__actions">
          <a class="feature-card__action" href="/forwarding">Manage</a>
        </div>
      </article>

      <article class="feature-card">
        <span class="feature-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M4 6h16v12H4z"></path>
            <path d="m4 6 8 7 8-7"></path>
            <path d="M16 12h4"></path>
            <path d="m18 10 2 2-2 2"></path>
          </svg>
        </span>
        <div class="feature-card__body">
          <h2 class="feature-card__title">Email forwarding</h2>
          <p class="feature-card__desc muted">Forward incoming emails to another address</p>
        </div>
        <div class="feature-card__actions">
          <a class="feature-card__action" href="/email">Manage</a>
        </div>
      </article>
    </div>

    <footer class="help-footer">
      <p>Need help?</p>
      <p>
        <a href={docsUrl}>View docs</a>
        <span aria-hidden="true"> · </span>
        <a href={contactUrl}>Contact</a>
      </p>
    </footer>
  </div>

  <script is:inline define:vars={{ apiBase, ROOT_DOMAIN }}>
    const siteHost = /** @type {HTMLElement} */ (document.getElementById("site-host"));
    const aliasesDesc = /** @type {HTMLElement} */ (document.getElementById("aliases-desc"));
    const viewPage = /** @type {HTMLAnchorElement} */ (document.getElementById("view-page"));
    const signOutBtns = /** @type {NodeListOf<HTMLButtonElement>} */ (
      document.querySelectorAll(".sign-out")
    );

    async function load() {
      const meRes = await fetch(apiBase + "/api/v1/session/me", { credentials: "include" });
      const me = await meRes.json();
      if (!meRes.ok || !me.authenticated) {
        window.location.href = "/sign-in";
        return;
      }

      const sitesRes = await fetch(apiBase + "/api/v1/sites/me", { credentials: "include" });
      const body = await sitesRes.json();
      if (!sitesRes.ok || !body.sites || !body.sites.length) {
        window.location.href = "/claim";
        return;
      }

      const sub = body.sites[0].subdomain;
      const host = sub + "." + ROOT_DOMAIN;
      siteHost.textContent = host;
      aliasesDesc.textContent = "Create @" + host + " addresses";
      viewPage.href = "https://" + host;
    }

    async function signOut() {
      for (const btn of signOutBtns) {
        btn.disabled = true;
      }
      await fetch(apiBase + "/api/v1/session", {
        method: "DELETE",
        credentials: "include",
      });
      window.location.href = "/sign-in";
    }

    for (const btn of signOutBtns) {
      btn.addEventListener("click", signOut);
    }

    load();
  </script>
</Layout>

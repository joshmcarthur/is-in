---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import { ROOT_DOMAIN } from "../siteDomain";

const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
---
<Layout title="Claim your name">
  <a class="back-link" href="/">‹ Back</a>
  <div class="stack">
    <h2 class="h2">Claim your name</h2>
    <p class="lede">This will be your unique address on {ROOT_DOMAIN}.</p>
    <form id="form" class="stack" novalidate>
      <div class="input-suffix">
        <input
          id="subdomain"
          name="subdomain"
          autocomplete="off"
          spellcheck="false"
          autocapitalize="off"
          required
          aria-describedby="avail"
        />
        <span class="suffix" aria-hidden="true">.{ROOT_DOMAIN}</span>
      </div>
      <p id="avail" class="status" role="status" aria-live="polite"></p>
      <button type="submit" class="btn btn-primary" id="continue" disabled>Continue</button>
      <p id="guest-hint" class="lede" hidden></p>
    </form>
    <p id="msg" class="status" role="alert" hidden></p>
  </div>
  <script is:inline define:vars={{ apiBase, ROOT_DOMAIN }}>
    const PENDING_SUB_KEY = "isin_pending_subdomain";

    async function me() {
      const res = await fetch(apiBase + "/api/v1/session/me", { credentials: "include" });
      if (!res.ok) return null;
      return res.json();
    }

    async function hasSite() {
      const res = await fetch(apiBase + "/api/v1/sites/me", { credentials: "include" });
      if (!res.ok) return false;
      const body = await res.json();
      return Array.isArray(body.sites) && body.sites.length > 0;
    }

    const subdomainInput = /** @type {HTMLInputElement} */ (document.getElementById("subdomain"));
    const avail = /** @type {HTMLElement} */ (document.getElementById("avail"));
    const continueBtn = /** @type {HTMLButtonElement} */ (document.getElementById("continue"));
    const form = /** @type {HTMLFormElement} */ (document.getElementById("form"));
    const msg = /** @type {HTMLElement} */ (document.getElementById("msg"));
    const guestHint = /** @type {HTMLElement} */ (document.getElementById("guest-hint"));

    let checkTimer = 0;
    let checkSeq = 0;
    let authenticated = false;
    let lastAvailableSubdomain = "";

    function updateContinueLabel() {
      if (!authenticated && lastAvailableSubdomain) {
        continueBtn.textContent = "Sign in to reserve";
      } else {
        continueBtn.textContent = "Continue";
      }
    }

    function updateGuestHint() {
      if (authenticated || !lastAvailableSubdomain) {
        guestHint.hidden = true;
        guestHint.textContent = "";
        return;
      }
      guestHint.hidden = false;
      guestHint.textContent =
        "We\u2019ll email you a code, then bring you back to reserve " +
        lastAvailableSubdomain +
        "." +
        ROOT_DOMAIN +
        ".";
    }

    function clearAvail() {
      avail.textContent = "";
      avail.className = "status";
      continueBtn.disabled = true;
      lastAvailableSubdomain = "";
      updateContinueLabel();
      updateGuestHint();
    }

    function setAvailSuccess(subdomain) {
      avail.textContent = "\u2713 " + subdomain + "." + ROOT_DOMAIN + " is available!";
      avail.className = "status status--success";
      continueBtn.disabled = false;
      lastAvailableSubdomain = subdomain;
      updateContinueLabel();
      updateGuestHint();
    }

    function setAvailError(text) {
      avail.textContent = text;
      avail.className = "status status--error";
      continueBtn.disabled = true;
      lastAvailableSubdomain = "";
      updateContinueLabel();
      updateGuestHint();
    }

    function scheduleAvailabilityCheck(subdomain) {
      clearTimeout(checkTimer);
      if (!subdomain) {
        clearAvail();
        return;
      }
      continueBtn.disabled = true;
      lastAvailableSubdomain = "";
      updateContinueLabel();
      updateGuestHint();
      const seq = ++checkSeq;
      checkTimer = window.setTimeout(async () => {
        const res = await fetch(apiBase + "/api/v1/availability", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ subdomain }),
        });
        if (seq !== checkSeq) return;
        const data = await res.json();
        const name = typeof data.subdomain === "string" ? data.subdomain : subdomain;
        if (data.available) {
          setAvailSuccess(name);
          return;
        }
        if (data.reason === "invalid_or_reserved") {
          setAvailError("Use letters, numbers, and hyphens.");
          return;
        }
        setAvailError(name + "." + ROOT_DOMAIN + " is not available.");
      }, 300);
    }

    subdomainInput.addEventListener("input", () => {
      scheduleAvailabilityCheck(subdomainInput.value.trim().toLowerCase());
    });

    function resolvePendingSubdomain() {
      const fromQuery = new URLSearchParams(window.location.search).get("subdomain");
      const fromStorage = sessionStorage.getItem(PENDING_SUB_KEY);
      const raw = (fromQuery ?? fromStorage ?? "").trim().toLowerCase();
      if (!raw) return "";
      sessionStorage.setItem(PENDING_SUB_KEY, raw);
      return raw;
    }

    (async () => {
      const u = await me();
      authenticated = !!(u && u.authenticated);
      if (authenticated && (await hasSite())) {
        window.location.href = "/dashboard";
        return;
      }
      updateContinueLabel();

      const pending = resolvePendingSubdomain();
      if (pending) {
        subdomainInput.value = pending;
        scheduleAvailabilityCheck(pending);
      }
    })();

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (continueBtn.disabled) return;

      const subdomain = subdomainInput.value.trim().toLowerCase();

      if (!authenticated) {
        sessionStorage.setItem(PENDING_SUB_KEY, subdomain);
        window.location.href = "/sign-in";
        return;
      }

      continueBtn.disabled = true;
      continueBtn.textContent = "Reserving\u2026";
      msg.hidden = true;

      const res = await fetch(apiBase + "/api/v1/sites/claim", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({ subdomain }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        if (data.error === "already_has_site") {
          window.location.href = "/dashboard";
          return;
        }
        msg.hidden = false;
        if (data.error === "subdomain_not_allowed") {
          msg.textContent = "That name isn't allowed under our usage policy.";
        } else if (data.error === "moderation_unavailable") {
          msg.textContent = "Couldn't verify that name right now. Try again.";
        } else if (data.error === "taken") {
          msg.textContent = "That name is taken.";
        } else {
          msg.textContent = data.error || "Could not reserve.";
        }
        msg.className = "status status--error";
        continueBtn.disabled = false;
        updateContinueLabel();
        return;
      }
      sessionStorage.removeItem(PENDING_SUB_KEY);
      sessionStorage.setItem("isin_site", subdomain);
      window.location.href = "/dashboard";
    });
  </script>
</Layout>
